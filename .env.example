# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# ── LLM provider (Robin + Sanji — user-facing responses) ─────────────────────
# Options: groq | anthropic | ollama | mock
LLM_PROVIDER=groq

# Groq (fast, free tier available — recommended for user responses)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude (alternative)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama — local LLM, no API key, no rate limits
# Install: https://ollama.com  then: ollama pull llama3.2
# In Docker use host.docker.internal instead of localhost
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Zoro LLM (background indexing — separate from user-facing LLM) ───────────
# Recommended: use Ollama here so indexing has zero cost and no rate limits
# while Robin/Sanji keep using Groq for fast user responses.
ZORO_LLM_PROVIDER=ollama
ZORO_OLLAMA_BASE_URL=http://host.docker.internal:11434
ZORO_OLLAMA_MODEL=llama3.2

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
NODE_ENV=development

# ── Agent behavior ────────────────────────────────────────────────────────────
AGENT_TIMEOUT_MS=30000
AGENT_MAX_RETRIES=3
AGENT_RETRY_DELAY_MS=1000

# ── Proactive crew chat ───────────────────────────────────────────────────────
# Agents randomly send conversations to the chat without being triggered
CREW_CHAT_ENABLED=true
# Base interval between messages (ms). Actual = ± 25% jitter. Default = 20 min
CREW_CHAT_INTERVAL_MS=1200000
# Minimum gap between proactive messages to same chat (anti-spam). Default = 10 min
CREW_CHAT_MIN_DELAY_MS=600000
# Skip chats silent for longer than this (ms). Default = 48 hours
CREW_CHAT_INACTIVE_THRESHOLD_MS=172800000

# ── Weather context (optional — improves crew conversation topics) ─────────────
# Use city name OR direct coordinates (coordinates take priority)
USER_CITY=Delhi
# USER_LATITUDE=28.6139
# USER_LONGITUDE=77.2090

# ── GitHub context source ─────────────────────────────────────────────────────
# Personal Access Token: github.com → Settings → Developer settings → PAT
# Needs: repo (read), read:user scopes
GITHUB_TOKEN=
GITHUB_USERNAME=your_github_username
GITHUB_MAX_RESULTS=5

# ── Zoro (knowledge builder) ──────────────────────────────────────────────────
# Zoro reads every repo file-by-file and builds a searchable knowledge base.
# Progress is saved to knowledge/.zoro-progress.json and survives restarts.
ZORO_ENABLED=true
# Number of parallel workers (each processes one file at a time)
ZORO_WORKERS=3
# How long a worker sleeps when nothing is pending (ms)
ZORO_WORKER_IDLE_MS=5000
# How often to re-check GitHub for new repos (ms, default 5 min)
ZORO_DISCOVERY_INTERVAL_MS=300000
ZORO_KNOWLEDGE_DIR=./knowledge

# ── Context search ────────────────────────────────────────────────────────────
# Directory Nami searches for relevant context. Defaults to ./knowledge
# In Docker: mount your docs at /app/knowledge or set this to the mount path
CONTEXT_ROOT_DIR=./knowledge
CONTEXT_SEARCH_DEPTH=5
CONTEXT_MAX_RESULTS=10

# ── Tony (health monitoring) ──────────────────────────────────────────────────
TONY_CHECK_INTERVAL_MS=10000
TONY_STUCK_THRESHOLD_MS=60000

# ── Task management ───────────────────────────────────────────────────────────
TASK_MAX_CONCURRENT=10
TASK_QUEUE_SIZE=1000

# ── Persistence ───────────────────────────────────────────────────────────────
# "file" = survive restarts (recommended); "memory" = in-memory only
PERSISTENCE_TYPE=file
DB_PATH=./data/store.json

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs with admin access
ADMIN_USER_IDS=123456789
ENABLE_TASK_INSPECTION=true

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set USE_MOCK_AGENTS=true to skip real LLM calls (uses deterministic stubs)
USE_MOCK_AGENTS=true
# Set USE_MOCK_TELEGRAM=true to skip the live Telegram listener
USE_MOCK_TELEGRAM=true
ENABLE_AUDIT_LOGS=true

# Telegram Configuration
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# Logging Configuration
LOG_LEVEL=debug
NODE_ENV=development

# Agent Configuration
AGENT_TIMEOUT_MS=30000
AGENT_MAX_RETRIES=3
AGENT_RETRY_DELAY_MS=1000

# Context Service Configuration
CONTEXT_SEARCH_DEPTH=3
CONTEXT_MAX_RESULTS=10

# Health Monitoring Configuration
TONY_CHECK_INTERVAL_MS=5000
TONY_STUCK_THRESHOLD_MS=60000

# Task Configuration
TASK_MAX_CONCURRENT=10
TASK_QUEUE_SIZE=1000
TASK_PERSISTENCE_ENABLED=true

# Admin Configuration
ADMIN_USER_IDS=123456789
ENABLE_TASK_INSPECTION=true

# Feature Flags
USE_MOCK_AGENTS=false
USE_MOCK_TELEGRAM=false
ENABLE_AUDIT_LOGS=true
